# =============================================================
#  Endee RAG Q&A — Environment Variables
# =============================================================

# Groq API Key (free at https://console.groq.com)
# Required for LLM-powered answer generation
GROQ_API_KEY=your_groq_api_key_here

# Endee Vector DB URL (default: local via Docker)
ENDEE_URL=http://localhost:8080

# Endee index name
ENDEE_INDEX_NAME=documents

# LLM model to use (via Groq)
LLM_MODEL=llama3-8b-8192

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding dimension (must match above model)
EMBEDDING_DIM=384
